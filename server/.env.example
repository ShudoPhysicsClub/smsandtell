# 統合サーバー設定例
PORT=35000
JWT_SECRET=change_me_jwt_secret

# TLS（本番環境では必須）
CERT_FILE=/etc/letsencrypt/live/tell.manh2309.org/fullchain.pem
KEY_FILE=/etc/letsencrypt/live/tell.manh2309.org/privkey.pem

# MariaDB 接続情報
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smsandtell
DB_PASSWORD=change_me_db_password
DB_NAME=smsandtell

# 直接 DSN を使いたい場合はこちらを設定してもよい
# DB_DSN=smsandtell:password@tcp(127.0.0.1:3306)/smsandtell?charset=utf8mb4&parseTime=true&loc=Local

# 静的ファイルディレクトリ（client/dist/ をコピーして配置）
STATIC_DIR=./static
