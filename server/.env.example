# 統合サーバー設定例
PORT=35000
JWT_SECRET=change_me_jwt_secret

# TLS（本番環境では必須）
CERT_FILE=/etc/letsencrypt/live/tell.manh2309.org/fullchain.pem
KEY_FILE=/etc/letsencrypt/live/tell.manh2309.org/privkey.pem

# SQLite DBファイルパス（省略時: smsandtell.db）
DB_PATH=/var/lib/smsandtell/smsandtell.db

# 静的ファイルディレクトリ（client/dist/ をコピーして配置）
STATIC_DIR=./static
